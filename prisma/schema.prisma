generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tool {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String
  description     String
  category        String
  pricing         String
  websiteUrl      String           @map("website_url")
  affiliateUrl    String?          @map("affiliate_url")
  features        String[]
  color           String           @default("text-foreground")
  bgGradient      String           @default("from-transparent to-transparent") @map("bg_gradient")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  cons            String[]
  icon            String?
  pros            String[]
  isFeatured      Boolean          @default(false) @map("is_featured")
  tier            String           @default("free")
  affiliateClicks AffiliateClick[]
  favorites       Favorite[]
  reviews         Review[]
  sponsorships    Sponsorship[]
  stackTools      StackTool[]
  testimonials    Testimonial[]
  communityStacks CommunityStack[] @relation("CommunityStackToTool")

  @@index([category])
  @@index([pricing])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([category, pricing])
  @@index([category, isFeatured])
  @@index([pricing, isFeatured])
  @@map("tools")
}

model Stack {
  id              String        @id @default(cuid())
  idField         String        @unique @map("id_field")
  name            String
  description     String?
  longDescription String?       @map("long_description")
  totalPrice      String?       @map("total_price")
  tags            String[]
  idealFor        String[]      @map("ideal_for")
  workflow        String[]
  icon            String?
  color           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  stackMetrics    StackMetrics?
  stackTools      StackTool[]
  stackViews      StackView[]
  testimonials    Testimonial[]

  @@map("stacks")
}

model StackTool {
  id        String   @id @default(cuid())
  stackId   String   @map("stack_id")
  toolId    String   @map("tool_id")
  createdAt DateTime @default(now()) @map("created_at")
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([stackId, toolId])
  @@map("stack_tools")
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String?
  content   String?
  date      String?
  author    String?
  category  String?
  readTime  String?  @map("read_time")
  image     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([createdAt])
  @@map("blog_posts")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?            @map("email_verified")
  image               String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  twoFABackupCodes    String[]             @map("two_fa_backup_codes")
  twoFAEnabled        Boolean              @default(false) @map("two_fa_enabled")
  twoFASecret         String?              @map("two_fa_secret")
  accounts            Account[]
  communityStackLikes CommunityStackLike[]
  communityStacks     CommunityStack[]
  favorites           Favorite[]
  reviews             Review[]
  sessions            Session[]
  stackViews          StackView[]
  testimonials        Testimonial[]
  userSavedStacks     UserSavedStack[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  toolId    String   @map("tool_id")
  rating    Int
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  toolId    String   @map("tool_id")
  createdAt DateTime @default(now()) @map("created_at")
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@map("favorites")
}

model AffiliateClick {
  id        String   @id @default(cuid())
  toolId    String   @map("tool_id")
  toolSlug  String   @map("tool_slug")
  toolName  String   @map("tool_name")
  url       String
  userAgent String?  @map("user_agent")
  referrer  String?
  ipAddress String?  @map("ip_address")
  abVariant String?  @map("ab_variant")
  createdAt DateTime @default(now()) @map("created_at")
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, createdAt])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

model EmailCapture {
  id        String   @id @default(cuid())
  email     String
  source    String   @default("exit_intent")
  toolSlug  String?  @map("tool_slug")
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, source])
  @@index([createdAt])
  @@map("email_captures")
}

model Submission {
  id          String   @id @default(cuid())
  toolName    String   @map("tool_name")
  description String
  websiteUrl  String   @map("website_url")
  category    String
  pricing     String
  email       String
  tier        String   @default("free")
  status      String   @default("pending")
  amount      Int      @default(0)
  paymentId   String?  @map("payment_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("submissions")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventId   String   @unique @map("event_id")
  type      String
  status    String   @default("received")
  error     String?
  payload   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider, createdAt])
  @@map("webhook_events")
}

model Sponsorship {
  id                   String    @id @default(cuid())
  provider             String    @default("stripe")
  placement            String
  status               String    @default("active")
  priceId              String?   @map("price_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  sponsorName          String?   @map("sponsor_name")
  sponsorUrl           String?   @map("sponsor_url")
  sponsorEmail         String?   @map("sponsor_email")
  sponsorCopy          String?   @map("sponsor_copy")
  toolId               String?   @map("tool_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  tool                 Tool?     @relation(fields: [toolId], references: [id])

  @@index([placement, status])
  @@index([currentPeriodEnd])
  @@map("sponsorships")
}

model Testimonial {
  id            String    @id @default(cuid())
  userId        String?   @map("user_id")
  stackId       String?   @map("stack_id")
  toolId        String?   @map("tool_id")
  rating        Int
  content       String
  metrics       Json?
  videoUrl      String?   @map("video_url")
  verified      Boolean   @default(false)
  verifiedAt    DateTime? @map("verified_at")
  featured      Boolean   @default(false)
  featuredOrder Int       @default(0) @map("featured_order")
  socialProof   Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  userAvatar    String?   @map("user_avatar")
  userCompany   String?   @map("user_company")
  userHandle    String?   @map("user_handle")
  userName      String?   @map("user_name")
  userRole      String?   @map("user_role")
  stack         Stack?    @relation(fields: [stackId], references: [id])
  tool          Tool?     @relation(fields: [toolId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])

  @@index([verified, featured])
  @@index([stackId, featured])
  @@index([createdAt])
  @@map("testimonials")
}

model StackMetrics {
  id               String   @id @default(cuid())
  stackId          String   @unique @map("stack_id")
  views            Int      @default(0)
  saves            Int      @default(0)
  shares           Int      @default(0)
  implementations  Int      @default(0)
  avgRating        Float    @default(0) @map("avg_rating")
  reviewCount      Int      @default(0) @map("review_count")
  popularityScore  Float    @default(0) @map("popularity_score")
  trendingRank     Int?     @map("trending_rank")
  lastCalculatedAt DateTime @default(now()) @map("last_calculated_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  stack            Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@index([popularityScore])
  @@index([trendingRank])
  @@map("stack_metrics")
}

model CommunityStack {
  id            String               @id @default(cuid())
  name          String
  description   String?
  isPublic      Boolean              @default(true) @map("is_public")
  isFeatured    Boolean              @default(false) @map("is_featured")
  featuredOrder Int                  @default(0) @map("featured_order")
  forkedFromId  String?              @map("forked_from_id")
  viewCount     Int                  @default(0) @map("view_count")
  saveCount     Int                  @default(0) @map("save_count")
  likeCount     Int                  @default(0) @map("like_count")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  curatorId     String               @map("curator_id")
  likes         CommunityStackLike[]
  curator       User                 @relation(fields: [curatorId], references: [id], onDelete: Cascade)
  forkedFrom    CommunityStack?      @relation("StackForks", fields: [forkedFromId], references: [id])
  forks         CommunityStack[]     @relation("StackForks")
  savedBy       UserSavedStack[]
  tools         Tool[]               @relation("CommunityStackToTool")

  @@index([isPublic, isFeatured])
  @@index([curatorId])
  @@index([createdAt])
  @@map("community_stacks")
}

model Content {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  excerpt        String?
  content        String
  type           ContentType
  status         ContentStatus @default(draft)
  authorId       String        @map("author_id")
  coverImage     String?       @map("cover_image")
  tags           String[]
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  publishedAt    DateTime?     @map("published_at")
  viewCount      Int           @default(0) @map("view_count")
  readingTime    Int           @default(0) @map("reading_time")
  relatedStacks  String[]      @map("related_stacks")
  relatedTools   String[]      @map("related_tools")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([type, status])
  @@index([status, publishedAt])
  @@index([tags])
  @@map("content")
}

model StackAdoption {
  id               String   @id @default(cuid())
  stackId          String   @map("stack_id")
  userId           String   @map("user_id")
  toolsAdopted     String[] @map("tools_adopted")
  productivityGain String?  @map("productivity_gain")
  timeSaved        String?  @map("time_saved")
  costSaved        String?  @map("cost_saved")
  testimonialId    String?  @map("testimonial_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([stackId, userId])
  @@index([stackId])
  @@index([userId])
  @@map("stack_adoptions")
}

model CommunityStackLike {
  id        String         @id @default(cuid())
  stackId   String         @map("stack_id")
  userId    String         @map("user_id")
  createdAt DateTime       @default(now()) @map("created_at")
  stack     CommunityStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stackId, userId])
  @@index([stackId])
  @@index([userId])
  @@index([createdAt])
  @@map("community_stack_likes")
}

model UserSavedStack {
  id        String         @id @default(cuid())
  stackId   String         @map("stack_id")
  userId    String         @map("user_id")
  createdAt DateTime       @default(now()) @map("created_at")
  stack     CommunityStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stackId, userId])
  @@index([stackId])
  @@index([userId])
  @@index([createdAt])
  @@map("user_saved_stacks")
}

model StackView {
  id        String   @id @default(cuid())
  stackId   String   @map("stack_id")
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([stackId, createdAt])
  @@index([userId])
  @@map("stack_views")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean  @default(true)
  error     String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum ContentType {
  blog
  guide
  comparison
  tutorial
  case_study
  changelog
}

enum ContentStatus {
  draft
  review
  published
  archived
}
